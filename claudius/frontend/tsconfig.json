{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./js",
    "rootDir": "./ts",
    "sourceMap": true
  },
  "include": [ "ts/**/*.ts" ],
  "lib": [ "ES2020", "DOM" ]
}